# ============================================================================
# ASAB — عصب  |  .htaccess جاهز لاستضافة Hostinger (Apache / SPA)
# ----------------------------------------------------------------------------
# ملف مكتفٍ بذاته: انسخ محتوى مجلد dist/ (ومعه هذا الملف) إلى public_html وخلاص.
# لا يحتاج أي إعداد إضافي بعده. الـ API بيتنادى على دومين منفصل (VITE_API_BASE_URL
# وقت البناء) فمفيش داعي لأي بروكسي هنا.
# كل التعليمات ملفوفة في <IfModule> فلو موديول مش متاح الملف يفضل شغّال بدون خطأ.
# ============================================================================

# منع استعراض محتويات المجلدات
Options -Indexes

# صفحة البداية
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ---- فرض HTTPS (يشمل حالة البروكسي في الاستضافة المشتركة) ----
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ---- لا تُعِد كتابة الملفات أو المجلدات الموجودة فعلاً ----
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ---- SPA fallback: أي مسار آخر يرجّع index.html (توجيه من طرف العميل) ----
  RewriteRule ^ index.html [L]
</IfModule>

# ============================================================================
# أنواع المحتوى (MIME) — تأكيد الأنواع الحديثة
# ============================================================================
<IfModule mod_mime.c>
  AddType application/javascript            .js .mjs
  AddType text/css                          .css
  AddType image/svg+xml                     .svg
  AddType application/json                  .json
  AddType application/manifest+json         .webmanifest
  AddType font/woff2                        .woff2
  AddType font/woff                         .woff
  AddType image/x-icon                      .ico
  AddType image/webp                        .webp
</IfModule>

# ============================================================================
# الضغط (gzip) لتسريع التحميل
# ============================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf
</IfModule>

# ============================================================================
# التخزين المؤقت (Cache)
#  - أصول Vite لها بصمة hash في الاسم → تخزين طويل (سنة) وثابت.
#  - index.html بدون تخزين → يضمن أن كل نشر جديد يظهر فوراً.
# ============================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # أصول مبنية ببصمة (assets/*) — سنة كاملة، غير قابلة للتغيّر
  <FilesMatch "\.(js|mjs|css|woff2|woff|ttf|svg|png|jpg|jpeg|gif|webp|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  # لا تخزّن index.html — عشان النسخة الجديدة تبان بعد كل نشر
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # ---- رؤوس أمان أساسية ----
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ============================================================================
# صفحات الأخطاء → ترجع للتطبيق (SPA)
# ============================================================================
ErrorDocument 404 /index.html
