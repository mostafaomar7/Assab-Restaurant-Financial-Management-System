# Vite frontend env — copy to .env (or .env.local) and fill in values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Backend base URL (no trailing slash).
# API calls go to ${BASE}/api/v1, Echo auth to ${BASE}/broadcasting/auth.
VITE_API_BASE_URL=https://ivory-snail-183262.hostingersite.com

# Pusher credentials (ask the backend owner). Leave empty to skip realtime.
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=mt1

# T13 — Supplier Portal («بوابة المورد»). Gates the WHOLE supplier section on a
# single flag. The backend registers /api/v1/asab/supplier/* only when its own
# FEATURE_ASAB_SUPPLIER_PORTAL=true (default off → 404). Set this to false to hide
# the supplier role/portal on the frontend too. Unset defaults to enabled here.
VITE_FEATURE_ASAB_SUPPLIER_PORTAL=true
